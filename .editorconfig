# EditorConfig — https://editorconfig.org
# KtLint — https://pinterest.github.io/ktlint/

root = true

# ──────────────────────────────────────────────
# All files
# ──────────────────────────────────────────────
[*]
charset                  = utf-8
end_of_line              = lf
indent_style             = space
insert_final_newline     = true   # Правило 4: пустая строка в конце каждого файла
trim_trailing_whitespace = true

# ──────────────────────────────────────────────
# Kotlin source files
# ──────────────────────────────────────────────
[*.{kt,kts}]
indent_size  = 4
max_line_length = 120

# ── Trailing commas ────────────────────────────────────────────────────────────
# Правило 1: trailing comma при объявлении класса/метода (constructor, params…)
# если не вмещается в 1 строку — обязательна запятая после последнего элемента.
ij_kotlin_allow_trailing_comma                  = true
ktlint_standard_trailing-comma-on-declaration-site = enabled

# Правило 2 (часть): trailing comma при вызове метода/создании экземпляра,
# если не вмещается в 1 строку — обязательна запятая после последнего аргумента.
ij_kotlin_allow_trailing_comma_on_call_site     = true
ktlint_standard_trailing-comma-on-call-site     = enabled

# ── Named arguments ────────────────────────────────────────────────────────────
# Правило 2 (часть): named arguments при вызове — проверяется через detekt
# (NamedArguments rule в detekt/detekt.yml)

# ── Импорты ───────────────────────────────────────────────────────────────────
ij_kotlin_imports_layout                        = *,java.**,javax.**,kotlin.**,^

# ── Форматирование ────────────────────────────────────────────────────────────
ktlint_standard_no-consecutive-blank-lines      = enabled
ktlint_standard_no-blank-line-before-rbrace     = enabled
# Отключено намеренно: конфликтует с кастомным detekt-правилом
# BlankLineAfterClassHeader (Правило 3), которое ТРЕБУЕТ пустую строку
# после заголовка класса/объекта перед первым членом.
ktlint_standard_no-empty-first-line-in-class-body = disabled
ktlint_standard_no-wildcard-imports             = enabled
ktlint_standard_spacing-around-operators        = enabled
ktlint_standard_spacing-between-declarations-with-annotations = enabled
ktlint_standard_blank-line-before-declaration   = enabled

# ── Именование ────────────────────────────────────────────────────────────────
ktlint_standard_class-naming                    = enabled
ktlint_standard_function-naming                 = enabled
ktlint_standard_property-naming                 = enabled

# Composable-функции именуются в PascalCase (см. CODE_STYLE.md) — исключаем их
# из правила function-naming, т.к. ktlint 1.x убрал встроенное исключение.
ktlint_function_naming_ignore_when_annotated_with = Composable

# ── Файлы сборки Gradle (.kts) ────────────────────────────────────────────────
[*.kts]
ktlint_standard_filename                        = disabled

# ──────────────────────────────────────────────
# XML (Android resources, manifests)
# ──────────────────────────────────────────────
[*.xml]
indent_size = 4

# ──────────────────────────────────────────────
# JSON / TOML / YAML
# ──────────────────────────────────────────────
[*.{json,toml,yaml,yml}]
indent_size = 2

# ──────────────────────────────────────────────
# Markdown
# ──────────────────────────────────────────────
[*.md]
trim_trailing_whitespace = false
